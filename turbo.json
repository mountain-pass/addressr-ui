{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "env": ["ADDRESSR_RAPIDAPI_KEY"]
    },
    "test:integration:browser": {
      "dependsOn": ["^build"],
      "env": ["ADDRESSR_RAPIDAPI_KEY"]
    },
    "lint": {}
  }
}
