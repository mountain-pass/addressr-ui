{
  "name": "@mountainpass/addressr-svelte",
  "version": "0.6.0",
  "description": "Svelte address autocomplete component for Australian address search via Addressr",
  "author": {
    "name": "Mountain Pass",
    "url": "https://mountain-pass.com.au"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist/"
  ],
  "sideEffects": [
    "*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "svelte": ">=4"
  },
  "dependencies": {
    "@mountainpass/addressr-core": "workspace:*",
    "@windyroad/link-header": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@testing-library/svelte": "^5.2.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0",
    "svelte": "^5.33.0",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "svelte",
    "address",
    "autocomplete",
    "australia",
    "addressr",
    "gnaf",
    "combobox",
    "hateoas"
  ]
}
