{
  "name": "addressr-ui",
  "private": true,
  "type": "module",
  "description": "UI components for Australian address search via Addressr",
  "author": {
    "name": "Mountain Pass",
    "url": "https://mountain-pass.com.au"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "test:integration:browser": "turbo test:integration:browser",
    "lint": "turbo lint",
    "pre-commit": "lint-staged",
    "push:watch": "bash scripts/push-and-watch.sh",
    "release:watch": "bash scripts/release-watch.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{json,css,md}": "prettier --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mountain-pass/addressr-ui.git"
  },
  "packageManager": "pnpm@10.12.1"
}
